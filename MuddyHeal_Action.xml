<Ui xmlns="http://www.blizzard.com/wow/ui/">
    <Button name="MuddyHeal_Unit_Template" virtual="true">
        <Size><AbsDimension x="105" y="35"/></Size>
        <HighlightTexture file="Interface\QuestFrame\UI-QuestTitleHighlight" alphaMode="ADD"/>
        <Backdrop bgFile="Interface\Buttons\WHITE8X8" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
            <EdgeSize><AbsValue val="8"/></EdgeSize>
            <BackgroundInsets><AbsDimension l="1" r="1" t="1" b="1"/></BackgroundInsets>
        </Backdrop>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parent_HealthBar">
                    <Anchors>
                        <Anchor point="TOPLEFT"><Offset><AbsDimension x="2" y="-2"/></Offset></Anchor>
                        <Anchor point="BOTTOMLEFT"><Offset><AbsDimension x="2" y="10"/></Offset></Anchor>
                    </Anchors>
                </Texture>
                <Texture name="$parent_ManaBar">
                    <Size><AbsDimension y="8"/></Size>
                    <Anchors><Anchor point="BOTTOMLEFT"><Offset><AbsDimension x="2" y="2"/></Offset></Anchor></Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString name="$parent_Name" inherits="GameFontHighlightSmall" justifyH="LEFT">
                    <Anchors><Anchor point="LEFT"><Offset><AbsDimension x="4" y="0"/></Offset></Anchor></Anchors>
                </FontString>
                <FontString name="$parent_HealthText" inherits="GameFontHighlightSmall" justifyH="RIGHT">
                    <Anchors><Anchor point="RIGHT"><Offset><AbsDimension x="-18" y="0"/></Offset></Anchor></Anchors>
                </FontString>
                <FontString name="$parent_BuffText" inherits="GameFontNormalSmall" justifyH="RIGHT">
                    <Anchors><Anchor point="RIGHT"><Offset><AbsDimension x="-4" y="0"/></Offset></Anchor></Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Button>
    <Frame name="MuddyHeal_MainFrame" parent="UIParent" movable="true" enableMouse="true">
        <Size><AbsDimension x="110" y="40"/></Size>
        <Anchors><Anchor point="CENTER"/></Anchors>
    </Frame>
</Ui>